           Background->None,ExpressionUUID->
           "ea3d266d-aa79-451a-b742-d3fd2b484cd1"]], "InlineCode",
          ExpressionUUID->
          "61611ed7-6a25-44d3-9d12-cb5e8184caaa"], \
"\<\"finite-dimensional-theorem-certificate\"\>", \
"\<\"finite-dimensional-theorem-certificate\"\>"},
        {Cell[TextData[{
          "Minimal countermodel when ",
          Cell[BoxData[Cell["Aminus \[NotSubset] ker chi",
            Background->None,ExpressionUUID->
            "e6a7804c-dc91-4f93-a3fe-217beea2e8f6"]], "InlineCode",

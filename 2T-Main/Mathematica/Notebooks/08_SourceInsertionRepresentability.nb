Cell["\<\
This notebook treats source-insertion representability as the exact linear \
problem \
\>", "Text",ExpressionUUID->"144074b1-0270-411e-81a6-1538c5a2bd86"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PiPhysR", " ", ".", " ", "Ftau"}], "==", "PiPhysT"}]], "Input",Expr\
essionUUID->"3d1346a4-11e7-4a94-9b5c-7be68453074f"],

Cell["at fixed cutoff. ", "Text",ExpressionUUID->"98beaa3c-cffd-4409-84c9-871242cda278"],


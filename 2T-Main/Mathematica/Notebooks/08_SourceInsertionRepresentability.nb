Cell[TextData[{
 "one exact solution: ",
 Cell[BoxData[Cell["{2, 3, 0}",
   Background->None,ExpressionUUID->"bf056bb4-473f-4be2-9acf-d0806b6021ab"]], 
  "InlineCode",ExpressionUUID->"354d9d2b-a46e-4344-bf3f-08adb67a7907"]
}], "Item",ExpressionUUID->"b2f11133-2868-49e9-a4d6-359cdca3d359"],

Cell[TextData[{

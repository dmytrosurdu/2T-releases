Notebook[{
Cell["05 Jcan Projection", "Title",ExpressionUUID->"e8029259-ad4a-4008-90c9-178437ede294"],

Cell["Scope", "Section",ExpressionUUID->"524c73d8-92c7-4747-9b6f-01bc200d0eb8"],

Cell[TextData[{
 "This notebook audits ",
 Cell[BoxData[Cell["thm:finite-cutoff-Jcan",
   Background->None,ExpressionUUID->"1f487b19-3535-4e88-b89d-3a9072dbc281"]], 
  "InlineCode",ExpressionUUID->"e4a3293b-9c03-4809-a290-0e4d1892717a"],
 " and ",
 Cell[BoxData[Cell["prop:Jcan-orth",
   Background->None,ExpressionUUID->"899bb787-4077-45e0-a67f-432731cd40ef"]], 
  "InlineCode",ExpressionUUID->"302c6ba8-7b62-4e6b-8ce7-eabb562dada0"],
 " by exact affine projection in finite-dimensional linear algebra. "
}], "Text",ExpressionUUID->"625af0d1-c963-4494-b344-92693deaecc8"],

Cell["Setup", "Section",ExpressionUUID->"bce34a1d-c747-4b3e-b85e-9a9b85957b05"],

Cell["For ", "Text",ExpressionUUID->"fe326336-f32d-4726-a98e-b41063d71067"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"[", 
   RowBox[{"Xi", "^", 
    RowBox[{"(", "1", ")"}]}], "]"}], "=", 
  RowBox[{"J0", "+", 
   RowBox[{"im", 
    RowBox[{"(", "U", ")"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"GA", "=", 
  RowBox[{
   RowBox[{"Transpose", "[", "U", "]"}], ".", "B", ".", "U"}]}]}], "Input",Exp\
ressionUUID->"348ca8f2-95d9-4687-b2b6-ddd03e5741db"],

Cell["define ", "Text",ExpressionUUID->"3e95498c-ec03-4d0c-89ba-617fc25daa38"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aStar", "=", 
   RowBox[{"-", 
    RowBox[{"LinearSolve", "[", 
     RowBox[{"GA", ",", 
      RowBox[{
       RowBox[{"Transpose", "[", "U", "]"}], ".", "B", ".", "J0"}]}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jcan", "=", 
   RowBox[{"J0", "+", 
    RowBox[{"U", ".", "aStar"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PA_B", "=", 
   RowBox[{"U", ".", 
    RowBox[{"LinearSolve", "[", 
     RowBox[{"GA", ",", 
      RowBox[{
       RowBox[{"Transpose", "[", "U", "]"}], ".", "B"}]}], "]"}]}]}], 
  ";"}]}], "Input",ExpressionUUID->"104022e5-8513-4a1b-9c1a-0174f2816400"],

Cell["so ", "Text",ExpressionUUID->"2f6f34a8-edc1-4857-be69-d54a470eca09"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Jcan", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", 
       RowBox[{"Length", "[", "J0", "]"}], "]"}], "-", "PA_B"}], ")"}], ".", 
    "J0"}]}], ";"}]], "Input",ExpressionUUID->"f5dc2a6f-0f6d-48ae-b75e-\
6b1fd924f90c"],

Cell["Exact certified example", "Section",ExpressionUUID->"651247d4-b773-4eed-9284-3a6232cabbfa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"5", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "3"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J0", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", 
     RowBox[{"-", "3"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chi", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsilon", "=", "1"}], ";"}]}], "Input",ExpressionUUID->"a75e5ddd-\
7465-45e7-aa07-5b9bcd0b1d8c"],

Cell["Exact output: ", "CodeText",ExpressionUUID->"cd21608c-faec-4272-87ec-8a28f41253aa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aStar", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "2"}], ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jcan", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PA_B", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
     "        ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
     "        ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "}"}]}], ";"}]}], "Input",Ex\
pressionUUID->"d1f3f6f9-f89f-4173-8315-4b03e411929c"],

Cell["Certified properties: ", "Text",ExpressionUUID->"10a6d01c-3467-4f7e-8dba-5d24f1b6a3cc"],

Cell[TextData[{
 Cell[BoxData[Cell["GA",
   Background->None,ExpressionUUID->"64e4786b-8798-405c-9998-9d16444d5cc4"]], 
  "InlineCode",ExpressionUUID->"e1f56a30-8638-4edb-ae47-ebf13a4e5735"],
 " is positive definite."
}], "Item",ExpressionUUID->"2143e973-5c26-4b14-bbe6-b2a63aaef935"],

Cell[TextData[{

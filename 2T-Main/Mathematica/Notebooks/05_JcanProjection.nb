 "."
}], "Item",ExpressionUUID->"f6440463-c08f-4e16-aad3-50a5bf946deb"],

Cell["\<\
Orthogonality is equivalent to minimality on the affine class.\
\>", "Item",ExpressionUUID->"6d50e0a7-b8d1-4a36-85cc-d6ea683d4d3d"],

Cell["The minimizer is unique.", "Item",ExpressionUUID->"d34db910-5d22-4acd-ac9d-9a92924c6902"],

Cell[TextData[{
 Cell[BoxData[Cell["Jcan",
   Background->None,ExpressionUUID->"b8e4ef1f-dbb5-45e4-ac06-85a688a79ba7"]], 
  "InlineCode",ExpressionUUID->"a24f8575-e254-455f-a74e-cd189637235a"],
 " is invariant under ",
 Cell[BoxData[Cell["J0 -> J0 + U h",
   Background->None,ExpressionUUID->"215f7cc2-0b1b-4761-b601-7e199a36f2fa"]], 
  "InlineCode",ExpressionUUID->"d218c2bc-bc7a-4ba7-8b6e-dede986769ad"],
 "."
}], "Item",ExpressionUUID->"cf0ccb29-a37e-4674-8c5d-6ae8965a9c9c"],

Cell[TextData[{
 Cell[BoxData[

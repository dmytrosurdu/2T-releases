 "."
}], "Item",ExpressionUUID->"4b635526-87c5-4f9f-82ad-43a3dc21d683"],

Cell[TextData[{
 Cell[BoxData[Cell["Transpose[U].B.Jcan = 0",
   Background->None,ExpressionUUID->"62ec70b2-3854-4ab7-913b-a8d57fca903a"]], 

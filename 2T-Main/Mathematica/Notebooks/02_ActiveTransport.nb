Cell["Here ", "Text",ExpressionUUID->"9448fe24-f721-4803-b93f-3141be3f5c95"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rhoDom", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", 

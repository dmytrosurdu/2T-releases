 Cell[BoxData[Cell["Aminus",
   Background->None,ExpressionUUID->"2c88dd1e-9adf-40de-9edc-3c8917434ee4"]], 
  "InlineCode",ExpressionUUID->"426f107a-3ab3-4075-a7f5-3ecd37a1bb5f"],
 "."
}], "Item",ExpressionUUID->"b006d778-59c9-4992-89fc-bd80f1c4d8fb"],

Cell[TextData[{
 Cell[BoxData[Cell["chi = nu^-1 rho^dom",
   Background->None,ExpressionUUID->"69977c72-f45e-4aa1-869d-028f3721a37b"]], 
  "InlineCode",ExpressionUUID->"30f7940d-922b-4114-a9a5-99c81ac36896"],
 " exactly."
}], "Item",ExpressionUUID->"6f7b5248-4d67-49b0-bdad-901a9f89b75e"],

Cell[TextData[{
 StyleBox["chi", "TI"],
 " is constant on the affine class ",
 Cell[BoxData[Cell["Jdesc + Aminus",
   Background->None,ExpressionUUID->"0020871c-57d2-4ea0-bb2d-b004ad4dacd5"]], 
  "InlineCode",ExpressionUUID->"4d3998a6-4e63-4ad2-a5e2-ed8305be979a"],
 "."
}], "Item",ExpressionUUID->"7301c21b-f7e9-4b4a-9557-c06ed39cb149"],

Cell[TextData[{
 Cell[BoxData[Cell["epsilon(lambda) = 1",
   Background->None,ExpressionUUID->"9664ee15-bbdd-4a76-824d-c4abebdbdfee"]], 
  "InlineCode",ExpressionUUID->"ca84c8e0-6dc3-47b0-b920-0229782a6544"],
 " on the whole accepted branch."
}], "Item",ExpressionUUID->"06261655-1e90-4371-93d1-e89143ab5784"],

Cell[TextData[{
 "The sign can only jump after excluding zeros of ",
 Cell[BoxData[Cell["rho^dom(Jdesc)",
   Background->None,ExpressionUUID->"10b2cfda-acd9-4af0-a25b-2ddb027f8d2c"]], 
  "InlineCode",ExpressionUUID->"9882fbb6-1f23-4432-9bda-a1c6583578d8"],
 " or ",
 StyleBox["nu", "TI"],
 "."
}], "Item",ExpressionUUID->"ec88fdea-a907-4617-af37-80208d413e98"],


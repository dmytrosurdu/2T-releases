  "InlineCode",ExpressionUUID->"4cb538bc-502f-4040-a0be-92a86e6d76b7"],
 "."
}], "Item",ExpressionUUID->"75c6c73e-4b63-4b04-a3bc-4f707a072c55"],

Cell[TextData[{
 "The sign is undefined at ",
 Cell[BoxData[Cell["lambda = 2",
   Background->None,ExpressionUUID->"ce314425-662b-47b7-a01c-3ea9d2b8de09"]], 
  "InlineCode",ExpressionUUID->"a927d26e-35f9-4f0b-83e1-890cd484e044"],

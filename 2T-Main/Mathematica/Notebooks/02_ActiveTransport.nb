Notebook[{
Cell["02 Active Transport", "Title",ExpressionUUID->"f10b8e40-83fa-45d9-ba72-081e69b6599f"],

Cell["Scope", "Section",ExpressionUUID->"5f32271e-46ee-4dff-a5eb-53bf4141e8cc"],

Cell[TextData[{
 "This notebook is the Task 3.5 hardening pass for ",
 Cell[BoxData[Cell["thm:active-response-transport-minimal",
   Background->None,ExpressionUUID->"85c06e04-4430-49a9-b080-98c365e4602a"]], 
  "InlineCode",ExpressionUUID->"942090bf-d13a-4f7c-80a1-f99ad016c010"],
 " and the weak export ",
 Cell[BoxData[Cell["thm:char-weak-interface",
   Background->None,ExpressionUUID->"6ee27481-57ea-4166-b54c-64c802b7d0bd"]], 
  "InlineCode",ExpressionUUID->"bba75c4f-3120-4adf-b9d3-e7c6cefdab3d"],
 ". It remains an exact-model audit, not a universal theorem over all \
admissible branches. "
}], "Text",ExpressionUUID->"7b6b3e83-00c2-4f1f-9b7c-672e7bb27234"],

Cell["Certified branch model", "Section",ExpressionUUID->"ff5fd5e2-9d29-485b-ac7a-8ecae886cc5c"],

Cell[TextData[{
 "Use the exact branch family from ",
 Cell[BoxData[Cell["MainProof`ActiveTransport",
   Background->None,ExpressionUUID->"4c79d223-6f56-4e66-81f9-bfcb22e1d557"]], 
  "InlineCode",ExpressionUUID->"3a17a487-1d11-45ac-b809-894f12d86925"],
 "CertifiedActiveTransportModel[]`: "
}], "CodeText",ExpressionUUID->"276f6e1c-1fbb-4974-ba8e-0215f9408dc6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{
   "MainProof`ActiveTransport`CertifiedActiveTransportModel", "[", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"audit", "=", 
   RowBox[{
   "MainProof`ActiveTransport`AuditActiveTransportModel", "[", "model", 
    "]"}]}], ";"}]}], "Input",ExpressionUUID->"7fbfdbc2-ca40-4411-bda9-\
c1f67bf1c23c"],

Cell["Certified input data: ", "CodeText",ExpressionUUID->"13552b5a-4e90-4b00-9c66-3d484fb62aa1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Aminus", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rhoDom", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", 
     RowBox[{"1", "+", "lambda"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nu", "=", 
   RowBox[{"1", "+", "lambda"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jdesc", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chi", "=", 
   RowBox[{
    RowBox[{"rhoDom", "/", "nu"}], "=", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "1"}], "}"}]}]}], ";"}]}], "Input",Expression\
UUID->"5eff4923-0e2d-49fd-b82c-45dd2d6842a1"],

Cell["Accepted connected component: ", "Text",ExpressionUUID->"9cd1dbbb-8c32-4f32-a6a6-2e29df9de449"],

Cell["1 <= lambda <= 3", "Program",ExpressionUUID->"a3df9dfe-ed4a-4848-b63e-06e33a19e0fe"],

Cell["Sign-defined connected component: ", "Text",ExpressionUUID->"7bdf0348-f8d9-44d6-88db-988878e81dbd"],

Cell["1 <= lambda <= 3", "Program",ExpressionUUID->"cdd88683-05b5-4aca-a510-6cd1858e43a8"],

Cell["Exact consequences on that component: ", "Text",ExpressionUUID->"d128061c-49f5-424a-9379-54cf070bc55d"],

Cell[TextData[{
 Cell[BoxData[Cell["rho^dom",
   Background->None,ExpressionUUID->"7c8060f8-65ba-46a8-a751-579b4d8b58d1"]], 
  "InlineCode",ExpressionUUID->"c71ba26d-38c5-4179-a9aa-2eac64a01c78"],

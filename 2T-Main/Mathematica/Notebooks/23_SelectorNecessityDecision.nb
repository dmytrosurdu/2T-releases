  Background->None,ExpressionUUID->
  "f0513ea1-5d91-4c41-989e-d6709b1cfba5"]], \
"InlineCode",ExpressionUUID->"27c1a69f-1fbe-4708-9724-c1657729483e"]], "Item",\
ExpressionUUID->"f6f36f64-2695-4354-984d-eb919cd0f80f"],

Cell["Exact setup", "Section",ExpressionUUID->"da28cafd-91bf-4d15-a781-f2ec442a9d0c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "Get", "[", "\"\</home/kray-l8/work/2T/Main/Mathematica/Kernel/Init.wl\>\"",
    "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"decision", "=", 
   RowBox[{
   "MainProof`SelectorNecessityDecision`SelectorNecessityDecision", "[", 
    "]"}]}], ";"}]}], "Input",ExpressionUUID->"99460105-c550-4d61-bb6f-\
07eb1b63a5b7"],

Cell["Decision query", "Section",ExpressionUUID->"5e253234-4799-4af0-9e5c-186723000028"],

Cell["\<\
Does the actual transported ambiguity class satisfy the boundary-safe \
criterion for structural reasons under split+welded restriction, or must a \
preferred selector be promoted? \
\>", "Text",ExpressionUUID->"82b37565-4409-4b1c-bd11-a226d34042fc"],

Cell["Exact synthesis", "Section",ExpressionUUID->"85a15b55-235f-4910-9865-01d7b4c00b1a"],

Cell[BoxData["decision"], "Input",ExpressionUUID->"f4f571d6-bdde-4ac0-8807-65ca34e2476f"],

Cell["Expected outcome", "Section",ExpressionUUID->"20bc334e-3a63-4b22-b23e-dd9d7a7686aa"],

Cell[TextData[{
 Cell[BoxData[Cell["Decision B",
   Background->None,ExpressionUUID->"6ae104a4-b07a-46af-8dca-9d785a283bb3"]], 
  "InlineCode",ExpressionUUID->"acbfb092-81ef-4bd5-9506-217c9b9fe090"],
 ": "
}], "Text",ExpressionUUID->"f968f396-d9f2-489b-bdbc-543c6b72ec59"],

Cell[BoxData[GridBox[{
   {
    PaneBox["\<\"That does not follow from the transported structure; visible \
diagonal controlled ambiguity survives, so a preferred selector must be \
promoted to core status.\"\>",
     BaseStyle->{"Text", FontColor -> LightDarkSwitched[
         GrayLevel[0.35], 
         GrayLevel[0.8602474]]},
     ImageMargins->5,
     ImageSize->{Full, Automatic}]}
  },
  AutoDelete->False,
  GridBoxBackground->{"Columns" -> {{
       LightDarkSwitched[
        GrayLevel[1], 
        GrayLevel[0.278317]]}}},
  GridBoxDividers->{"ColumnsIndexed" -> {1 -> Directive[
        LightDarkSwitched[
         RGBColor[0.87, 0.94, 1], 
         RGBColor[0.2491127, 0.3295188, 0.4231198]], 
        AbsoluteThickness[4]]}, "Rows" -> {{False}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Text", \
"BlockQuote",
 Background->None,ExpressionUUID->"dba0c973-b8ce-4503-bafd-3a3b04aa8cce"],

Cell["Why the decision is forced", "Section",ExpressionUUID->"8d5b6308-b4fe-42ea-8af1-00a3e8115632"],

Cell["\<\
The controlled boundary theorem reduces representative-independence to \
block-centrality or mod-null block-centrality.\
\>", "Item",ExpressionUUID->"1cd0bda3-a77f-487d-bf48-c5c51302c87a"],

Cell["\<\
No tested natural boundary null ideal is both stable and nontrivial.\
\>", "Item",ExpressionUUID->"4ce9dbc9-748a-4b21-9e93-e8f7b31dbca3"],

Cell["\<\
The actual exported transported ambiguity basis has an exact unsafe boundary \
realization with a visible diagonal controlled block.\
\>", "Item",ExpressionUUID->"b3a79dd2-db5b-4992-9f35-a3825b64d119"],

Cell["\<\
Therefore boundary restriction alone does not close Main\[CloseCurlyQuote]s \
selector problem at finite cutoff.\
\>", "Item",ExpressionUUID->"bd3b831b-c576-4602-8240-06752029a207"],

Cell["Artifact bundle", "Section",ExpressionUUID->"58d5453c-ca77-461b-bf3a-93c4bb7f2a6e"],

Cell[TextData[{
 "Run ",
 Cell[BoxData[Cell["\<\
/home/kray-l8/work/2T/Main/Mathematica/Reports/\
RunTransportedBoundarySelectorDecision.wl\
\>",
   Background->None,ExpressionUUID->"6f7fffff-16bb-455e-8a97-526b52c0f1d7"]], 
  "InlineCode",ExpressionUUID->"a09cd809-9ca0-44ab-a6b8-cbe040c9d645"],
 " to refresh the full report, updated ledger, certificate bundle, \
imported-assumptions note, and manuscript-facing remark snippet."
}], "Text",ExpressionUUID->"9ffce6a8-4a66-452c-807b-5d57d789cad5"]

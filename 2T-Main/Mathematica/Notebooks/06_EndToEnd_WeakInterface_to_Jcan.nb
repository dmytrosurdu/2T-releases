Notebook[{
Cell["06 End To End Weak Interface to Jcan", "Title",ExpressionUUID->"ee459fb6-ec5a-4d32-bd70-b4f490ae3314"],

Cell["Scope", "Section",ExpressionUUID->"1ca67f64-8f1a-44dc-b46c-75ba81ebac32"],

Cell["This notebook is the sprint milestone certificate for ", "Text",ExpressionUUID->"71052666-245f-4332-8cc7-ad4837b03fbc"],

Cell["(E^-, Aminus, [Xi^(1)], chi, epsilon) => B => Jcan", "Program",ExpressionUUID->"d2fdf647-a21f-4fdc-9e5d-dc7b1df55724"],

Cell["\<\
using the certified transport model from Task 3.5, the calibration \
constructor from Task 4, and the affine projection theorem from Task 5. \
\>", "Text",ExpressionUUID->"30e21f03-38c1-449f-88bb-bb74f4997663"],

Cell["Exact pipeline", "Section",ExpressionUUID->"17776b2c-2125-4b2d-a38c-ac538bf872fc"],

Cell["Step 1: weak interface from transport", "Subsection",ExpressionUUID->"0d4be261-14fd-4ee5-8241-a8aa59857732"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"model", "=", 
   RowBox[{
   "MainProof`ActiveTransport`CertifiedActiveTransportModel", "[", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chi", "=", 
   RowBox[{"MainProof`ActiveTransport`DerivedChi", "[", "model", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsilon", "=", 
   RowBox[{"chi", ".", 
    RowBox[{"model", "[", "\"\<Jdesc\>\"", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Aminus", "=", 
   RowBox[{"model", "[", "\"\<Aminus\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jdesc", "=", 
   RowBox[{"model", "[", "\"\<Jdesc\>\"", "]"}]}], ";"}]}], "Input",Expression\
UUID->"4cd10d56-5928-471b-93c9-52008b7bb2ca"],

Cell["Exact result: ", "CodeText",ExpressionUUID->"4ed68a85-bc62-467d-b734-6ac9071fe38e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"chi", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsilon", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jdesc", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ";"}]}], "Input",ExpressionUUI\
D->"9f2e887d-6609-468d-a095-9b0f8d43bfe9"],

Cell["Step 2: construct calibration", "Subsection",ExpressionUUID->"36659a9b-fa19-4f12-83ff-c3826094e950"],

Cell["Choose exact auxiliary data ", "Text",ExpressionUUID->"541b5275-20d2-455c-a4b2-fe0deb9181f7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"h", "=", 
   RowBox[{"{", 
    RowBox[{"2", ",", 
     RowBox[{"-", "1"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J0", "=", 
   RowBox[{
    RowBox[{"Jdesc", "+", 
     RowBox[{"Aminus", ".", "h"}]}], "=", 
    RowBox[{"{", 
     RowBox[{"2", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"N", "=", 
   RowBox[{
   "MainProof`CommonProofTools`KernelBasisFromFunctional", "[", "chi", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Q", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "3"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"beta", "=", "5"}], ";"}]}], "Input",ExpressionUUID->"0c50ce5d-0b4a-\
46a3-9628-fa34ff736a62"],

Cell["Then ", "Text",ExpressionUUID->"693839f7-e6e2-4748-9c3a-9682ad2db909"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cal", "=", 
   RowBox[{
   "MainProof`Calibration`CalibrationData", "[", "\[IndentingNewLine]", "  ", 
    
    RowBox[{"chi", ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"epsilon", " ", "Jdesc"}], ",", "\[IndentingNewLine]", "  ", 
     "beta", ",", "\[IndentingNewLine]", "  ", "Q", ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"\"\<KernelBasis\>\"", "->", "N"}], ",", "\[IndentingNewLine]", 
     "  ", 
     RowBox[{"\"\<Aminus\>\"", "->", "Aminus"}], ",", "\[IndentingNewLine]", 
     "  ", 
     RowBox[{"\"\<Representative\>\"", "->", "Jdesc"}], ",", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"\"\<Epsilon\>\"", "->", "epsilon"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"f4737f7a-d99f-4f3d-a661-\
f4cef260f50e"],

Cell["Exact calibration matrix: ", "CodeText",ExpressionUUID->"41be97de-3929-4b27-8adc-81d7bad40041"],

Cell[BoxData[
 RowBox[{
  RowBox[{"B", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"3", ",", "1", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
     "     ", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
     "     ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "5"}], "}"}]}], "}"}]}], ";"}]], "Input",Exp\
ressionUUID->"4661cd7d-5ccb-477a-a802-7906ef4fe39f"],

Cell["Step 3: compute the canonical representative", "Subsection",ExpressionUUID->"258c308e-cdda-44dc-8be0-44daebd3636f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"canon", "=", 
   RowBox[{
   "MainProof`CanonicalRepresentative`CanonicalRepresentativeData", "[", 
    "\[IndentingNewLine]", "  ", 
    RowBox[{
    "Aminus", ",", "\[IndentingNewLine]", "  ", "B", ",", 
     "\[IndentingNewLine]", "  ", "J0", ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"\"\<Chi\>\"", "->", "chi"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"\"\<Epsilon\>\"", "->", "epsilon"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"6e4610a8-c4e2-44fc-a21d-\
bb5f7059f6b9"],

Cell["Exact output: ", "CodeText",ExpressionUUID->"aaaf456f-f9d5-4168-817e-cc2d658e51d7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aStar", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "2"}], ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Jcan", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ";"}]}], "Input",ExpressionUUI\
D->"bffd9fb9-6d24-4db2-b3d5-f7f4aef28a83"],

Cell[TextData[{
 "So the shifted representative projects back to the calibrating \
representative ",
 Cell[BoxData[Cell["epsilon Jdesc",
   Background->None,ExpressionUUID->"1d68ab55-e0a8-42a5-92ce-bb09a530ed67"]], 
  "InlineCode",ExpressionUUID->"7967a7ae-6db9-4f98-93c1-7bc175acbad6"],
 ". "
}], "Text",ExpressionUUID->"27cba666-9aeb-4df4-8027-1ae7e7aac5a0"],

Cell["Re-run", "Section",ExpressionUUID->"bbfdc4cd-9613-44b4-a73e-2a02e7f7abc9"],

Cell[BoxData[
 RowBox[{"Get", 
  "[", "\"\</home/kray-l8/work/2T/Main/Mathematica/Reports/\
RunWeakInterfaceToJcan.wl\>\"", "]"}]], "Input",ExpressionUUID->"355eadae-\
45db-4b68-99e3-b57d5546ae21"],

Cell["Full symbolic artifact: ", "Text",ExpressionUUID->"d73b5b44-bdfa-4988-bf12-895846639b51"],

Cell["\<\
Main/Mathematica/Certificates/WeakInterfaceToJcan_Certificates.wl\
\>", "Program",ExpressionUUID->"017e9a3c-84b6-4432-9391-e8728fe018d3"],

Cell["Status", "Section",ExpressionUUID->"b09b2775-798c-4f20-a1ce-de4e98dd42ca"],

Cell[BoxData[
 PaneBox[
  PaneBox[
   StyleBox[
    TagBox[
     TagBox[GridBox[{
        {
         TagBox["\<\"Claim\"\>",
          HoldForm], 
         TagBox["\<\"Status\"\>",
          HoldForm], 
         TagBox["\<\"ScopeClass\"\>",
          HoldForm]},
        {"\<\"Weak interface extracted from the certified transport \
model\"\>", "\<\"exact finite-dimensional certificate\"\>", \
"\<\"exact-model-certificate\"\>"},
        {Cell[TextData[{
          "Calibration constructed exactly from ",

            Background->None,ExpressionUUID->
            "5a688926-7256-4b9d-9c5d-30c03beba2c4"]], "InlineCode",
           ExpressionUUID->"a98e32fe-adac-49b4-89c4-1b0c6ced0609"]
         }],ExpressionUUID->
          "85ecb219-a5fb-4966-b4ad-4bc4e105b38e"], \
"\<\"finite-dimensional-theorem-certificate\"\>", \
"\<\"finite-dimensional-theorem-certificate\"\>"},
        {Cell[TextData[{
          Cell[BoxData[Cell["TickData",
            Background->None,ExpressionUUID->
            "b037ceba-09e7-4cc2-9533-28d389eb5f8c"]], "InlineCode",
           ExpressionUUID->"e0111461-f569-4cb3-ae1a-872fd5cc82cf"],
          " with transported ",
          StyleBox["chi", "TI"],
          ", calibrated ",
          Cell[BoxData[Cell["B",
            Background->None,ExpressionUUID->
            "4fa7b505-c54b-4d74-8150-ea7cd1e56865"]], "InlineCode",
           ExpressionUUID->"d1593a22-b36f-4cb5-b597-0cbd37f52833"],
          ", and shifted ",
          Cell[BoxData[Cell["J0",
            Background->None,ExpressionUUID->
            "6ecff273-781a-43ad-adf5-146e9552e59d"]], "InlineCode",
           ExpressionUUID->"899d179d-b63a-4b9f-ab54-ace342e35a7e"],
          " validates"
         }],ExpressionUUID->
          "d57c7547-da6e-464a-8325-d88da3b3cec3"], "\<\"exact \
finite-dimensional certificate\"\>", "\<\"schema-validator\"\>"},
        {Cell[TextData[{
          Cell[BoxData[Cell["Jcan",
            Background->None,ExpressionUUID->
            "5f6711bc-b996-4def-98e9-a3285637e747"]], "InlineCode",
           ExpressionUUID->"43e01fa8-c480-467e-8672-d0347b4a035a"],
          " computed exactly and satisfies ",
          Cell[BoxData[Cell["chi(Jcan) = epsilon",
            Background->None,ExpressionUUID->
            "ff9ddc4d-bae4-4273-a11d-2bac249a8647"]], "InlineCode",
           ExpressionUUID->"fe5c4170-d541-4585-bdce-60ea59c113ce"]
         }],ExpressionUUID->
          "b28e51dd-1fc7-425a-aadb-d146f93ae902"], \
"\<\"finite-dimensional-theorem-certificate\"\>", \
"\<\"finite-dimensional-theorem-certificate\"\>"},
        {Cell[TextData[{
          Cell[BoxData[Cell["Jcan",
            Background->None,ExpressionUUID->
            "a37c06e7-e227-4ff6-997a-d129a162f7a1"]], "InlineCode",
           ExpressionUUID->"b0fb7e1a-1289-4718-9f30-b6abdaf00cb8"],
          " equals the calibrating representative after projection"
         }],ExpressionUUID->
          "ad49c431-709a-452c-b05e-2128e36252a0"], \
"\<\"finite-dimensional-theorem-certificate\"\>", \
"\<\"finite-dimensional-theorem-certificate\"\>"},
        {Cell[TextData[{
          "End-to-end milestone ",
